<Window x:Class="CatsCafeWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cat's Cafe" Height="640" Width="860" MinHeight="600" MinWidth="800"
        Background="#FFFFBDC5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFFFBDC5" />
            <Setter Property="Foreground" Value="#670626" />
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FAEBD7" />
            <Setter Property="Foreground" Value="#670626" />
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#670626" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FAEBD7" />
            <Setter Property="FontFamily" Value="Times New Roman" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FAEBD7" />
            <Setter Property="FontFamily" Value="Times New Roman" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </Window.Resources>

    <Grid Background="#670626">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0"
              Background="#4a0418"
              Foreground="#FAEBD7"
              FontFamily="Times New Roman"
              FontSize="14"
              Padding="4,3">
            <MenuItem Header="Файл" Foreground="#FAEBD7">
                <MenuItem Header="Нова задача" Click="MenuNew_Click" Foreground="#670626" />
                <MenuItem Header="Зберегти у файл" Click="MenuSave_Click" Foreground="#670626" />
                <MenuItem Header="Відкрити з файлу" Click="MenuOpen_Click" Foreground="#670626" />
                <Separator />
                <MenuItem Header="Вихід" Click="MenuExit_Click" Foreground="#670626" />
            </MenuItem>
            <MenuItem Header="Допомога" Foreground="#FAEBD7">
                <MenuItem Header="Про програму" Click="MenuAbout_Click" Foreground="#670626" />
            </MenuItem>
        </Menu>

        <!-- Заголовок -->
        <StackPanel Grid.Row="1" Margin="0,12,0,6">
            <Label Content="Cat's Cafe"
                   FontSize="26" FontWeight="Bold"
                   HorizontalAlignment="Center" />
            <Label Content="Оформлення замовлення"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Основний вміст -->
        <Grid Grid.Row="2" Margin="20,6,20,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Список страв - звичайний ListBox з готовими текстовими рядками
                 (кожен рядок - це вже відформатований String, без окремого класу-рядка) -->
            <ListBox x:Name="ItemsListBox"
                     Grid.Column="0"
                     Margin="0,0,16,0"
                     Background="#FAEBD7"
                     Foreground="#670626"
                     FontFamily="Courier New"
                     FontSize="14"
                     BorderBrush="#670626"
                     BorderThickness="1" />

            <!-- Панель керування -->
            <StackPanel Grid.Column="1">
                <Label Content="Опис страви (3-20 симв.):" />
                <TextBox x:Name="TxtDescription" TextChanged="TxtDescription_TextChanged" PreviewKeyDown="TxtDescription_PreviewKeyDown" />

                <Label Content="Ціна:" />
                <TextBox x:Name="TxtPrice" TextChanged="TxtPrice_TextChanged" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Додати страву" Click="BtnAdd_Click" />
                    <Button Content="Видалити вибрану" Click="BtnRemove_Click" />
                </StackPanel>

                <Separator Margin="0,10" Background="#4a0418" />

                <Label Content="Чайові:" FontWeight="Bold" />
                <RadioButton x:Name="RbTipPercent" Content="Відсоток від суми" GroupName="TipGroup" IsChecked="True" />
                <RadioButton x:Name="RbTipAmount" Content="Фіксована сума" GroupName="TipGroup" />
                <RadioButton x:Name="RbTipNone" Content="Без чайових" GroupName="TipGroup" />

                <TextBox x:Name="TxtTipValue" Margin="0,6,0,8" />
                <Button Content="Застосувати чайові" Click="BtnApplyTip_Click" HorizontalAlignment="Left" />
            </StackPanel>
        </Grid>

        <!-- Підсумок рахунку -->
        <Border Grid.Row="3" Margin="20,4,20,10"
                Background="#FAEBD7" BorderBrush="#670626" BorderThickness="1"
                CornerRadius="2" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Net Total" FontFamily="Times New Roman" FontWeight="Bold" Foreground="#670626" />
                    <TextBlock x:Name="TxtNetTotal" Text="$0.00" FontFamily="Courier New" Foreground="#670626" FontSize="15" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Tip Amount" FontFamily="Times New Roman" FontWeight="Bold" Foreground="#670626" />
                    <TextBlock x:Name="TxtTipAmount" Text="$0.00" FontFamily="Courier New" Foreground="#670626" FontSize="15" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="TxtGstLabel" Text="Total GST" FontFamily="Times New Roman" FontWeight="Bold" Foreground="#670626" />
                    <TextBlock x:Name="TxtGstAmount" Text="$0.00" FontFamily="Courier New" Foreground="#670626" FontSize="15" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Total Amount" FontFamily="Times New Roman" FontWeight="Bold" Foreground="#670626" />
                    <TextBlock x:Name="TxtTotalAmount" Text="$0.00" FontFamily="Courier New" Foreground="#670626" FontSize="16" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Нижні кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="20,0,0,14">
            <Button Content="Очистити все" Click="BtnClearAll_Click" />
            <Button Content="Зберегти у файл" Click="BtnSave_Click" />
            <Button Content="Завантажити з файлу" Click="BtnLoad_Click" />
            <Button Content="Вихід" Click="BtnExit_Click" />
        </StackPanel>
    </Grid>
</Window>
